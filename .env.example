# =====================================================
# Environment Variables
# =====================================================
#
# Setup:
#
# 1. Copy this file and rename it to:
#    - .env              (shared/default environment)
#    - .env.development  (your local development environment)
#
# 2. Replace the placeholder values with your own.
#
# 3. Never commit .env or .env.development to Git.
#
# Priority in Next.js:
# .env.development > .env
#
# =====================================================

NEXT_PUBLIC_BASE_URL=https://dummyjson.com
